{
  "name": "pi-radio-suomi",
  "version": "0.1.0",
  "description": "Pi extension for controlling Finnish and Swedish radio streams from /radio.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "radio",
    "suomi",
    "finland",
    "sweden",
    "swedish",
    "sveriges-radio",
    "nordic"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/DxTa/pi-radio-suomi.git"
  },
  "files": [
    "index.ts",
    "channels.ts",
    "sr-channels.ts",
    "scripts/update-sr-channels.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "update:sr-channels": "node scripts/update-sr-channels.mjs --write",
    "check:sr-channels": "node scripts/update-sr-channels.mjs --check"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
